# GestualAI API — variáveis de ambiente (copie para server/.env)
#
# Por omissão, a API usa persistência LOCAL (SQLite em server/data/) com
# autenticação local — não é preciso configurar nada. As variáveis abaixo só
# são necessárias para usar Supabase em vez do modo local.

# Porta do servidor.
PORT=8787

# Origem(ns) permitida(s) para CORS (frontend). Use o URL do Vite em dev.
CORS_ORIGIN=http://localhost:5173

# Segredo para assinar os JWT no modo local (opcional; gerado e persistido
# automaticamente em server/data/.jwt-secret se não for definido).
# GESTUALAI_JWT_SECRET=

# --- Supabase (opcional) — se definidas, a API usa Supabase em vez do modo local ---
SUPABASE_URL=
# Chave anónima (pública) — usada para os fluxos de auth (register/login).
SUPABASE_ANON_KEY=
# Chave de service-role (SECRETA, apenas no servidor) — acesso à BD.
# NUNCA exponha esta chave no frontend.
SUPABASE_SERVICE_ROLE_KEY=

# Diretório dos modelos TF.js a servir (por omissão ../public/models).
# MODELS_DIR=
