# GestualAI (frontend) — variáveis de ambiente (copie para .env)
#
# URL da API backend. Em desenvolvimento pode ficar vazio: o Vite encaminha
# /api para http://localhost:8787 (ver vite.config.js). Em produção, defina o
# URL público da API.
VITE_API_URL=

# Caminho/URL para o modelo de classificação de gestos LGP exportado (TensorFlow.js).
# Por omissão, a app procura em /models/lgp-gestures/model.json.
# Em produção pode apontar para a API: VITE_GESTURE_MODEL_URL=/api/model/lgp-gestures/model.json
# Enquanto o modelo treinado não existir, é usado o classificador heurístico de demonstração.
VITE_GESTURE_MODEL_URL=/models/lgp-gestures/model.json

# Nota: a configuração do Supabase (URL, chaves) foi movida para o servidor
# (ver server/.env.example). O frontend já não acede ao Supabase diretamente.
